#
# boards/arm/rp23xx/picocalc-rp2350b/configs/full/defconfig
#
# eUX OS full configuration
# Includes: ROMFS root filesystem, display, keyboard, LVGL,
# audio, Wi-Fi, runit services, all built-in apps
#

# --- Host ---
CONFIG_HOST_LINUX=y

# --- Architecture ---
CONFIG_ARCH="arm"
CONFIG_ARCH_ARM=y
CONFIG_ARCH_CHIP="rp23xx"
CONFIG_ARCH_CHIP_RP23XX=y
CONFIG_RP23XX_RP2350B=y
CONFIG_ARCH_BOARD_CUSTOM=y
CONFIG_ARCH_BOARD_CUSTOM_NAME="picocalc-rp2350b"
CONFIG_ARCH_BOARD_CUSTOM_DIR="boards/arm/rp23xx/picocalc-rp2350b"
CONFIG_ARCH_BOARD_CUSTOM_DIR_RELPATH=y
CONFIG_ARCH_RAMVECTORS=y
CONFIG_ARCH_STACKDUMP=y
CONFIG_BOOT_RUNFROMFLASH=y
CONFIG_BOARD_LOOPSPERMSEC=15000
CONFIG_START_YEAR=2025
CONFIG_START_MONTH=1
CONFIG_START_DAY=1
CONFIG_RAM_START=0x20000000
CONFIG_RAM_SIZE=532480
CONFIG_BOARD_LATE_INITIALIZE=y

# --- Build ---
CONFIG_APPS_DIR="../nuttx-apps"
CONFIG_BUILTIN=y
CONFIG_DEBUG_FULLOPT=y
CONFIG_DEBUG_SYMBOLS=y

# --- Peripherals ---
CONFIG_RP23XX_UART0=y
CONFIG_UART0_SERIAL_CONSOLE=y
CONFIG_UART0_BAUD=115200
CONFIG_RP23XX_SPI=y
CONFIG_RP23XX_SPI0=y
CONFIG_RP23XX_SPI1=y
CONFIG_RP23XX_SPI1_SCK_GPIO=10
CONFIG_RP23XX_SPI1_TX_GPIO=11
CONFIG_RP23XX_SPI1_RX_GPIO=12
CONFIG_RP23XX_SPI1_CS_GPIO=13
CONFIG_ARCH_BOARD_COMMON=y
CONFIG_RP23XX_I2C=y
CONFIG_RP23XX_I2C1=y
CONFIG_RP23XX_I2C1_SDA_GPIO=6
CONFIG_RP23XX_I2C1_SCL_GPIO=7
CONFIG_I2C=y
CONFIG_I2C_DRIVER=y

# --- Display ---
CONFIG_DRIVERS_VIDEO=y
CONFIG_VIDEO_FB=y
CONFIG_FB_UPDATE=y
CONFIG_PICOCALC_LCD_ST7365P=y

# --- Keyboard ---
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_PICOCALC_KEYBOARD=y

# --- PSRAM ---
CONFIG_PICOCALC_PSRAM=y

# --- Audio ---
CONFIG_PICOCALC_AUDIO_PWM=y

# --- SD Card + Filesystems ---
CONFIG_MMCSD=y
CONFIG_MMCSD_SPI=y
CONFIG_FS_FAT=y
CONFIG_FAT_LCNAMES=y
CONFIG_FS_PROCFS=y
CONFIG_FS_TMPFS=y
CONFIG_FS_ROMFS=y

# --- ROMFS root filesystem (/etc) ---
CONFIG_NSH_ROMFSETC=y
CONFIG_NSH_ROMFSRC=y
CONFIG_NSH_INITSCRIPT="init.d/rcS"
CONFIG_NSH_ROMFSMOUNTPT="/etc"
CONFIG_NSH_ROMFSDEVNO=0
CONFIG_NSH_ROMFSSECTSIZE=64

# --- LVGL v9 ---
CONFIG_GRAPHICS_LVGL=y
CONFIG_LV_USE_NUTTX=y
CONFIG_LV_USE_NUTTX_FBDEV=y
CONFIG_LV_MEM_SIZE_KILOBYTES=48
CONFIG_LV_COLOR_DEPTH_16=y
CONFIG_LV_DPI_DEF=160
CONFIG_LV_FONT_MONTSERRAT_12=y
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_16=y
CONFIG_LV_FONT_UNSCII_8=y
CONFIG_LV_FONT_DEFAULT_MONTSERRAT_14=y
CONFIG_LV_USE_LABEL=y
CONFIG_LV_USE_BUTTON=y
CONFIG_LV_USE_BUTTONMATRIX=y
CONFIG_LV_USE_TABLE=y
CONFIG_LV_USE_TEXTAREA=y
CONFIG_LV_USE_KEYBOARD=y
CONFIG_LV_USE_ROLLER=y
CONFIG_LV_USE_DROPDOWN=y
CONFIG_LV_USE_CHECKBOX=y
CONFIG_LV_USE_SWITCH=y
CONFIG_LV_USE_SLIDER=y
CONFIG_LV_USE_BAR=y
CONFIG_LV_USE_LIST=y
CONFIG_LV_USE_TABVIEW=y
CONFIG_LV_USE_MSGBOX=y
CONFIG_LV_USE_WIN=y

# --- Network ---
CONFIG_ALLOW_BSD_COMPONENTS=y
CONFIG_DRIVERS_IEEE80211=y
CONFIG_DRIVERS_WIRELESS=y
CONFIG_IEEE80211_BROADCOM_FULLMAC_GSPI=y
CONFIG_IEEE80211_INFINEON_CYW43439=y
CONFIG_NET=y
CONFIG_NET_TCP=y
CONFIG_NET_UDP=y
CONFIG_NET_ICMP=y
CONFIG_NET_SOCKOPTS=y
CONFIG_NET_TCP_WRITE_BUFFERS=y
CONFIG_NET_IPv4=y
CONFIG_NETDEV_WIRELESS_IOCTL=y
CONFIG_NETDB_DNSCLIENT=y
CONFIG_NETUTILS_NETLIB=y
CONFIG_NETUTILS_DHCPC=y
CONFIG_NETDEV_LATEINIT=y
CONFIG_NETUTILS_CJSON=y
CONFIG_WIRELESS_WAPI=y
CONFIG_PICOCALC_WIFI=y

# --- Crypto (for SSH/TLS) ---
CONFIG_CRYPTO=y
CONFIG_ALLOW_GPL_COMPONENTS=y
CONFIG_CRYPTO_WOLFSSL=y
CONFIG_CRYPTO_WOLFSSH=y
CONFIG_CRYPTO_WOLFSSH_SCP=y

# --- Internal Flash Filesystem ---
CONFIG_MTD=y
CONFIG_RP23XX_FLASH_FILE_SYSTEM=y
CONFIG_FS_LITTLEFS=y

# --- Pseudo-terminals (for local terminal) ---
CONFIG_PSEUDOTERM=y

# --- NSH (as embedded shell for pcterm app) ---
CONFIG_NSH_LIBRARY=y
CONFIG_NSH_BUILTIN_APPS=y
CONFIG_NSH_ARCHINIT=y
CONFIG_NSH_READLINE=y
CONFIG_READLINE_CMD_HISTORY=y
CONFIG_SYSTEM_NSH=y
CONFIG_SYSTEM_VI=y
CONFIG_SYSTEM_VI_COLS=40
CONFIG_SYSTEM_VI_ROWS=20
CONFIG_SYSLOG_CONSOLE=y

# --- ELF loader (for third-party apps) ---
CONFIG_ELF=y
CONFIG_LIBC_EXECFUNCS=y

# --- Hostname ---
CONFIG_PICOCALC_HOSTNAME="eux"
CONFIG_NET_HOSTNAME=y
CONFIG_LIBC_HOSTNAME_MAX=32

# --- Entry point ---
CONFIG_EXAMPLES_PCTERM=y
CONFIG_INIT_ENTRYPOINT="eux_init"
CONFIG_INIT_STACKSIZE=8192

# --- Debug (minimal for production) ---
CONFIG_DEBUG_FEATURES=y
CONFIG_DEBUG_ERROR=y
CONFIG_SYSLOG=y
CONFIG_RAMLOG=y
CONFIG_RAMLOG_SYSLOG=y
CONFIG_RAMLOG_BUFSIZE=8192
CONFIG_SYSLOG_DEVPATH="/dev/kmsg"

# --- Scheduling & Multi-threading ---
CONFIG_IRQCHAIN=y
CONFIG_RR_INTERVAL=200
CONFIG_SCHED_WAITPID=y
CONFIG_SCHED_WORKQUEUE=y
CONFIG_SCHED_HPWORK=y
CONFIG_SCHED_HPWORKSTACKSIZE=2048
CONFIG_SCHED_LPWORK=y
CONFIG_SCHED_LPWORKSTACKSIZE=2048
CONFIG_NFILE_DESCRIPTORS_PER_BLOCK=8
CONFIG_ARCH_INTERRUPTSTACK=2048
CONFIG_SCHED_CPULOAD=y
CONFIG_SCHED_CPULOAD_SYSCLK=y

# --- POSIX Threads (full support) ---
CONFIG_PTHREAD_MUTEX_TYPES=y
CONFIG_PTHREAD_MUTEX_BOTH=y
CONFIG_PTHREAD_STACK_DEFAULT=4096
CONFIG_CANCELLATION_POINTS=y
CONFIG_SCHED_HAVE_PARENT=y
CONFIG_SIG_DEFAULT=y
CONFIG_PTHREAD_MUTEX_DEFAULT_PRIO_INHERIT=y
CONFIG_PRIORITY_INHERITANCE=y
CONFIG_SEM_PREALLOCHOLDERS=8

# --- Filesystem ---
CONFIG_FS_PROCFS_REGISTER=y
CONFIG_PSEUDOFS_SOFTLINKS=y

# --- System Information Commands ---
CONFIG_SYSTEM_LSCPU=y
CONFIG_SYSTEM_LSI2C=y
CONFIG_SYSTEM_LSSPI=y
CONFIG_SYSTEM_SCREENFETCH=y
CONFIG_SYSTEM_CLOCKSET=y
CONFIG_SYSTEM_HOSTNAME=y
CONFIG_SYSTEM_PCMINIPKG=y
CONFIG_SYSTEM_PCWIFI=y
CONFIG_SYSTEM_DMESG=y

# --- Interpreters (lightweight scripting) ---
CONFIG_INTERPRETERS_LUA=y
CONFIG_INTERPRETERS_LUA_CORELIBS=y
CONFIG_INTERPRETERS_QUICKJS=y
CONFIG_INTERPRETERS_QUICKJS_MINI=y
CONFIG_INTERPRETERS_QUICKJS_STACKSIZE=16384
CONFIG_LIBC_LOCALE=y
CONFIG_SYSTEM_SYSTEM=y

# --- I2C/SPI diagnostics tools ---
CONFIG_SYSTEM_I2CTOOL=y
CONFIG_SYSTEM_SPITOOL=y

# --- CLI SSH/SCP/keygen commands for NSH ---
CONFIG_SYSTEM_PCSSH=y
CONFIG_SYSTEM_PCSCP=y
CONFIG_SYSTEM_PCSSH_KEYGEN=y
CONFIG_SYSTEM_PCTIME=y
CONFIG_SYSTEM_PCNTP=y
CONFIG_SYSTEM_PCBT=y

# --- Games ---
CONFIG_GAMES_BRICKMATCH=y
CONFIG_GAMES_BRICKMATCH_USE_LCD_SCREEN=y
CONFIG_GAMES_BRICKMATCH_USE_CONSOLEKEY=y
CONFIG_GAMES_SNAKE=y
CONFIG_GAMES_SNAKE_USE_CONSOLEKEY=y

# --- Message Queues (IPC for threading) ---
CONFIG_MQ_MAXMSGSIZE=64

# --- Named Semaphores ---
CONFIG_FS_NAMED_SEMAPHORES=y
