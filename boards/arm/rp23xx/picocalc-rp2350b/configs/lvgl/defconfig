#
# boards/arm/rp23xx/picocalc-rp2350b/configs/lvgl/defconfig
#
# LVGL + Display + Keyboard configuration for PicoCalc RP2350B-Plus-W
# Purpose: GUI framework validation with launcher and status bar
#
# Extends nsh config with: display driver, LVGL, keyboard input
#

# --- (include nsh base options) ---
# Architecture, SPI, I2C, SD, PSRAM, NSH — same as nsh/defconfig

# --- Host ---
CONFIG_HOST_LINUX=y

CONFIG_ARCH="arm"
CONFIG_ARCH_ARM=y
CONFIG_ARCH_CHIP="rp23xx"
CONFIG_ARCH_CHIP_RP2350B=y
CONFIG_ARCH_BOARD="picocalc-rp2350b"
CONFIG_ARCH_BOARD_PICOCALC_RP2350B=y
CONFIG_BOARD_LOOPSPERMSEC=15000
CONFIG_START_YEAR=2025
CONFIG_START_MONTH=1
CONFIG_START_DAY=1
CONFIG_RAM_START=0x20000000
CONFIG_RAM_SIZE=524288
CONFIG_BOARD_LATE_INITIALIZE=y

CONFIG_RP23XX_UART0=y
CONFIG_UART0_SERIAL_CONSOLE=y
CONFIG_UART0_BAUD=115200

CONFIG_RP23XX_SPI0=y
CONFIG_RP23XX_SPI1=y
CONFIG_RP23XX_I2C1=y
CONFIG_RP23XX_I2C1_SDA_GPIO=6
CONFIG_RP23XX_I2C1_SCL_GPIO=7
CONFIG_I2C=y
CONFIG_I2C_DRIVER=y

CONFIG_MMCSD=y
CONFIG_MMCSD_SPI=y
CONFIG_FS_FAT=y
CONFIG_PICOCALC_PSRAM=y

# --- Display ---
CONFIG_VIDEO_FB=y
CONFIG_PICOCALC_LCD_ST7365P=y
CONFIG_PICOCALC_LCD_SPI_FREQ=25000000

# --- Keyboard ---
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_PICOCALC_KEYBOARD=y

# --- LVGL ---
CONFIG_GRAPHICS_LVGL=y
CONFIG_LV_MEM_CUSTOM=y
CONFIG_LV_MEM_SIZE_KILOBYTES=48
CONFIG_LV_COLOR_DEPTH_16=y
CONFIG_LV_COLOR_16_SWAP=y
CONFIG_LV_DPI_DEF=160
CONFIG_LV_HOR_RES_MAX=320
CONFIG_LV_VER_RES_MAX=320
CONFIG_LV_USE_LOG=y
CONFIG_LV_LOG_LEVEL_WARN=y

# LVGL display driver: framebuffer
CONFIG_LV_PORT_USE_FBDEV=y
CONFIG_LV_TICK_CUSTOM=y

# LVGL built-in fonts
CONFIG_LV_FONT_MONTSERRAT_12=y
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_16=y
CONFIG_LV_FONT_UNSCII_8=y
CONFIG_LV_FONT_DEFAULT_MONTSERRAT_14=y

# LVGL widgets
CONFIG_LV_USE_LABEL=y
CONFIG_LV_USE_BTN=y
CONFIG_LV_USE_BTNMATRIX=y
CONFIG_LV_USE_TABLE=y
CONFIG_LV_USE_TEXTAREA=y
CONFIG_LV_USE_KEYBOARD=y
CONFIG_LV_USE_ROLLER=y
CONFIG_LV_USE_DROPDOWN=y
CONFIG_LV_USE_CHECKBOX=y
CONFIG_LV_USE_SWITCH=y
CONFIG_LV_USE_SLIDER=y
CONFIG_LV_USE_BAR=y
CONFIG_LV_USE_LIST=y
CONFIG_LV_USE_TABVIEW=y
CONFIG_LV_USE_MSGBOX=y
CONFIG_LV_USE_WIN=y

# --- NSH (reduced, GUI is primary) ---
CONFIG_NSH_LIBRARY=y
CONFIG_NSH_BUILTIN_APPS=y
CONFIG_SYSTEM_NSH=y
CONFIG_INIT_ENTRYPOINT="nsh_main"
CONFIG_INIT_STACKSIZE=4096

# --- Filesystem ---
CONFIG_FS_PROCFS=y
CONFIG_FS_FAT=y

# --- Debug (reduced for GUI config) ---
CONFIG_DEBUG_FEATURES=y
CONFIG_DEBUG_ERROR=y
CONFIG_SYSLOG=y
